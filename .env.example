# Optional: timeouts (seconds)
DEEPGRAM_TIMEOUT=4
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=hi
GEMINI_TIMEOUT=3
GEMINI_MODEL=gemini-2.5-flash
SILK_MODEL=mulberry
SILK_TIMEOUT=5
TURN_BUDGET=15
